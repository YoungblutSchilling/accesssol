{
  "name": "@accesssol/react",
  "version": "0.1.0",
  "description": "Accessible transaction review and status primitives for Solana React applications.",
  "type": "module",
  "main": "./dist/accesssol.cjs",
  "module": "./dist/accesssol.js",
  "types": "./dist/types/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/sdk/index.d.ts",
      "import": "./dist/accesssol.js",
      "require": "./dist/accesssol.cjs"
    },
    "./styles.css": "./dist/accesssol.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run check && npm run build:lib && npm run build:demo",
    "build:demo": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "vite",
    "prepare": "npm run build:lib",
    "prepack": "npm run build:lib",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "homepage": "https://youngblutschilling.github.io/accesssol/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YoungblutSchilling/accesssol.git"
  },
  "bugs": {
    "url": "https://github.com/YoungblutSchilling/accesssol/issues"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-core": "^4.10.2",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.8.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
